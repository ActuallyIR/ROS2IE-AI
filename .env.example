# ROS2 Agent Configuration
# Copy this to .env and fill in your values

# ─── LLM Provider ────────────────────────────────────────────
# Options: openai | anthropic | ollama
ROS2_AGENT_LLM_PROVIDER=anthropic

# Model name (depends on provider)
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Anthropic: claude-sonnet-4-5-20251001, claude-haiku-4-5-20251001 (recommended: cheaper)
# Ollama: llama3.2, mistral, codellama
ROS2_AGENT_LLM_MODEL=claude-haiku-4-5-20251001

# API Keys
ROS2_AGENT_OPENAI_API_KEY=sk-...
ROS2_AGENT_ANTHROPIC_API_KEY=sk-ant-...

# Ollama (if using local models)
ROS2_AGENT_OLLAMA_BASE_URL=http://localhost:11434

# ─── ROS 2 Settings ──────────────────────────────────────────
# ROS Domain ID (default: 0)
ROS2_AGENT_ROS_DOMAIN_ID=0

# ROS 2 distribution (humble | iron | jazzy | rolling)
ROS2_AGENT_ROS_DISTRO=humble

# Optional: path to your ROS 2 workspace to source before commands
# ROS2_AGENT_WORKSPACE_PATH=/home/user/ros2_ws

# ─── Agent Settings ──────────────────────────────────────────
# Maximum tool-call iterations per query
ROS2_AGENT_MAX_ITERATIONS=15

# Enable verbose logging of tool calls
ROS2_AGENT_VERBOSE=false

# ─── Web UI Settings ─────────────────────────────────────────
ROS2_AGENT_WEB_HOST=0.0.0.0
ROS2_AGENT_WEB_PORT=8080
